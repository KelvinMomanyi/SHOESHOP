<section class="customer-page section-band">
  <div class="page-width customer-auth">
    <div class="section-heading">
      <p class="eyebrow">{{ shop.name }}</p>
      <h1>Reset password</h1>
    </div>
    {%- form 'reset_customer_password', class: 'customer-form' -%}
      {{ form.errors | default_errors }}
      <div>
        <label for="ResetPassword">{{ 'customer.login.password' | t }}</label>
        <input id="ResetPassword" class="field__input" type="password" name="customer[password]" autocomplete="new-password" required>
      </div>
      <div>
        <label for="ResetPasswordConfirmation">Confirm password</label>
        <input id="ResetPasswordConfirmation" class="field__input" type="password" name="customer[password_confirmation]" autocomplete="new-password" required>
      </div>
      <button class="button" type="submit">Reset password</button>
    {%- endform -%}
  </div>
</section>
