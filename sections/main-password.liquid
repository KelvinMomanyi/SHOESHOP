<section class="password-section">
  <div class="password-section__media" aria-hidden="true">
    {%- if section.settings.image != blank -%}
      {%- render 'responsive-image',
        image: section.settings.image,
        class: 'password-section__image',
        sizes: '100vw',
        loading: 'eager'
      -%}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'password-section__image placeholder-svg' }}
    {%- endif -%}
  </div>

  <div class="password-section__content">
    <p class="eyebrow">{{ shop.name }}</p>
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.text }}</p>

    {%- form 'storefront_password', class: 'password-form' -%}
      {{ form.errors | default_errors }}
      <label class="visually-hidden" for="Password">{{ 'customer.login.password' | t }}</label>
      <input id="Password" class="field__input" type="password" name="password" autocomplete="current-password" placeholder="{{ 'customer.login.password' | t }}">
      <button class="button" type="submit">{{ section.settings.button_label }}</button>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Password page",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Opening soon"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Enter the password to preview the store."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Enter"
    }
  ]
}
{% endschema %}
