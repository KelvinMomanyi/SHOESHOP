<section class="newsletter-section section-band color-ink">
  <div class="newsletter-section__inner page-width reveal-item">
    <div>
      {%- if section.settings.kicker != blank -%}
        <p class="eyebrow">{{ section.settings.kicker }}</p>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.text != blank -%}
        <p>{{ section.settings.text }}</p>
      {%- endif -%}
      {%- if section.settings.image != blank -%}
        <div class="newsletter-section__media media-frame">
          {%- render 'responsive-image',
            image: section.settings.image,
            class: 'media-frame__image',
            sizes: '(min-width: 990px) 34vw, 100vw'
          -%}
        </div>
      {%- endif -%}
    </div>

    {%- form 'customer', class: 'newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <label class="visually-hidden" for="NewsletterEmail-{{ section.id }}">{{ 'general.newsletter.label' | t }}</label>
      <input
        id="NewsletterEmail-{{ section.id }}"
        class="field__input"
        type="email"
        name="contact[email]"
        value="{{ form.email }}"
        autocorrect="off"
        autocapitalize="off"
        autocomplete="email"
        placeholder="{{ 'general.newsletter.placeholder' | t }}"
        required
      >
      <button class="button button--light" type="submit">{{ section.settings.button_label }}</button>
      {%- if form.posted_successfully? -%}
        <p class="form-status">{{ 'general.newsletter.success' | t }}</p>
      {%- elsif form.errors -%}
        <p class="form-status form-status--error">{{ form.errors | default_errors }}</p>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Stay with Treadora"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New drops, fit notes, and care tips"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Footwear launches, restocks, limited colorways, and practical notes for finding the right pair."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
