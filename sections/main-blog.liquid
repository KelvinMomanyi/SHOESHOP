<section class="blog-page section-band">
  <div class="page-width">
    <div class="section-heading">
      <p class="eyebrow">{{ blog.articles_count }} articles</p>
      <h1>{{ blog.title }}</h1>
    </div>

    {%- paginate blog.articles by section.settings.articles_per_page -%}
      <div class="article-grid">
        {%- for article in blog.articles -%}
          <article class="article-card reveal-item">
            <a class="article-card__media media-frame" href="{{ article.url }}">
              {%- render 'responsive-image',
                image: article.image,
                class: 'media-frame__image',
                sizes: '(min-width: 990px) 33vw, 100vw'
              -%}
            </a>
            <p class="eyebrow">{{ article.published_at | date: format: 'abbreviated_date' }}</p>
            <h2><a href="{{ article.url }}">{{ article.title }}</a></h2>
            {%- if article.excerpt_or_content != blank -%}
              <p>{{ article.excerpt_or_content | strip_html | truncatewords: 24 }}</p>
            {%- endif -%}
          </article>
        {%- endfor -%}
      </div>
      {%- render 'pagination', paginate: paginate -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Main blog",
  "settings": [
    {
      "type": "range",
      "id": "articles_per_page",
      "label": "Articles per page",
      "min": 3,
      "max": 24,
      "step": 3,
      "default": 9
    }
  ]
}
{% endschema %}
