<section class="rich-text-section section-band">
  <div class="rich-text-section__inner page-width reveal-item">
    {%- if section.settings.kicker != blank -%}
      <p class="eyebrow">{{ section.settings.kicker }}</p>
    {%- endif -%}
    <h2>{{ section.settings.heading }}</h2>
    {%- if section.settings.text != blank -%}
      <div class="rte">{{ section.settings.text }}</div>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a class="button" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Rich text",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Note"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Designed to sell with a point of view"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Use this section for brand notes, product context, policies, and campaign messaging.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Rich text"
    }
  ]
}
{% endschema %}
