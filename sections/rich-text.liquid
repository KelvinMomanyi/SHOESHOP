<section class="rich-text-section section-band">
  <div class="rich-text-section__inner rich-text-section__inner--{{ section.settings.alignment }} page-width reveal-item">
    {%- if section.settings.image != blank -%}
      <div class="rich-text-section__media media-frame">
        {%- render 'responsive-image',
          image: section.settings.image,
          class: 'media-frame__image',
          sizes: '(min-width: 990px) 48vw, 100vw'
        -%}
      </div>
    {%- endif -%}
    {%- if section.settings.kicker != blank -%}
      <p class="eyebrow">{{ section.settings.kicker }}</p>
    {%- endif -%}
    <h2>{{ section.settings.heading }}</h2>
    {%- if section.settings.text != blank -%}
      <div class="rte">{{ section.settings.text }}</div>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a class="button" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Rich text",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Note"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built for every stride"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Use this section for fit guidance, material notes, footwear care, sizing details, and campaign messaging.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Content alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "center"
    }
  ],
  "presets": [
    {
      "name": "Rich text"
    }
  ]
}
{% endschema %}
