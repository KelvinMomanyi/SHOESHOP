<section class="not-found section-band">
  <div class="page-width empty-state">
    {%- if section.settings.kicker != blank -%}
      <p class="eyebrow">{{ section.settings.kicker }}</p>
    {%- endif -%}
    <h1>{{ section.settings.heading }}</h1>
    {%- if section.settings.text != blank -%}
      <p>{{ section.settings.text }}</p>
    {%- endif -%}
    {%- if section.settings.show_search -%}
      <form action="{{ routes.search_url }}" method="get" role="search" class="main-search-form">
        <input type="hidden" name="type" value="product,page,article">
        <label class="visually-hidden" for="Search404-{{ section.id }}">{{ 'accessibility.search' | t }}</label>
        <input id="Search404-{{ section.id }}" class="field__input" type="search" name="q" placeholder="{{ 'general.search.placeholder' | t }}">
        <button class="button" type="submit">{{ 'general.search.search' | t }}</button>
      </form>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a class="button" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">{{ section.settings.button_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "404",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "404"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page not found"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "The page you requested does not exist."
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Continue shopping"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ]
}
{% endschema %}
