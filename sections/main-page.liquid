<section class="page-section section-band">
  <div class="page-width page-section__inner">
    <div class="section-heading">
      <p class="eyebrow">{{ shop.name }}</p>
      <h1>{{ page.title }}</h1>
    </div>
    <div class="rte page-section__content">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main page"
}
{% endschema %}
