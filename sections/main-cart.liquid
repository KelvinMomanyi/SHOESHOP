<section class="cart-page section-band">
  <div class="page-width">
    <div class="section-heading">
      <p class="eyebrow">{{ cart.item_count }} items</p>
      <h1>{{ 'cart.general.title' | t }}</h1>
    </div>

    {%- if cart.item_count == 0 -%}
      <div class="empty-state">
        <p>{{ section.settings.empty_text }}</p>
        {%- if section.settings.continue_shopping_label != blank -%}
          <a class="button" href="{{ section.settings.continue_shopping_link | default: routes.all_products_collection_url }}">{{ section.settings.continue_shopping_label }}</a>
        {%- endif -%}
      </div>
    {%- else -%}
      {%- form 'cart', cart, class: 'cart-form' -%}
        <div class="cart-form__table-wrap">
          <table class="cart-form__table">
            <caption class="visually-hidden">{{ 'cart.general.title' | t }}</caption>
            <thead>
              <tr>
                <th scope="col"><span class="visually-hidden">Image</span></th>
                <th scope="col">Product</th>
                <th scope="col">Unit price</th>
                <th scope="col">Total</th>
                <th scope="col">{{ 'accessibility.quantity' | t }}</th>
              </tr>
            </thead>
            <tbody>
              {%- for item in cart.items -%}
                {%- render 'cart-line-item', item: item -%}
              {%- endfor -%}
            </tbody>
          </table>
        </div>

        <div class="cart-form__footer">
          {%- if section.settings.show_cart_note -%}
            <div class="cart-note">
              <label for="CartNote-{{ section.id }}">{{ 'cart.general.note' | t }}</label>
              <textarea id="CartNote-{{ section.id }}" class="field__input" name="note" rows="4">{{ cart.note }}</textarea>
            </div>
          {%- endif -%}

          <div class="cart-summary">
            {%- for discount_application in cart.cart_level_discount_applications -%}
              <div class="cart-summary__row">
                <span>{{ discount_application.title }}</span>
                <strong>-{{ discount_application.total_allocated_amount | money }}</strong>
              </div>
            {%- endfor -%}

            <div class="cart-summary__row cart-summary__row--total">
              <span>{{ 'cart.general.subtotal' | t }}</span>
              <strong>{{ cart.total_price | money_with_currency }}</strong>
            </div>

            {%- if cart.taxes_included -%}
              <p>{{ 'cart.general.tax_included' | t }}</p>
            {%- endif -%}
            <p>{{ 'cart.general.shipping_at_checkout' | t }}</p>

            <button class="button button--secondary" type="submit" name="update">{{ 'cart.general.update' | t }}</button>
            <button class="button" type="submit" name="checkout">{{ 'cart.general.checkout' | t }}</button>
            {%- if section.settings.show_dynamic_checkout and additional_checkout_buttons -%}
              <div class="cart-summary__accelerated-checkout additional-checkout-buttons">
                {{ content_for_additional_checkout_buttons }}
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endform -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Main cart",
  "settings": [
    {
      "type": "textarea",
      "id": "empty_text",
      "label": "Empty cart text",
      "default": "Your cart is empty."
    },
    {
      "type": "text",
      "id": "continue_shopping_label",
      "label": "Continue shopping button label",
      "default": "Continue shopping"
    },
    {
      "type": "url",
      "id": "continue_shopping_link",
      "label": "Continue shopping button link"
    },
    {
      "type": "checkbox",
      "id": "show_cart_note",
      "label": "Show cart note",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout buttons",
      "default": true
    }
  ]
}
{% endschema %}
