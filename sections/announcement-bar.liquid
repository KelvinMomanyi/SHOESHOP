{%- if section.settings.text != blank -%}
  <aside
    class="announcement-bar"
    role="region"
    aria-label="Announcement"
    style="--announcement-background: {{ section.settings.color_background }}; --announcement-text: {{ section.settings.color_text }};"
  >
    {%- if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}" class="announcement-bar__link">{{ section.settings.text }}</a>
    {%- else -%}
      <p>{{ section.settings.text }}</p>
    {%- endif -%}
  </aside>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Free shipping over $100"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "color",
      "id": "color_background",
      "label": "Background",
      "default": "#a6bd2f"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Text",
      "default": "#111111"
    }
  ]
}
{% endschema %}
