<section class="scroll-story section-band color-paper">
  <div class="scroll-story__intro page-width reveal-item">
    {%- if section.settings.kicker != blank -%}
      <p class="eyebrow">{{ section.settings.kicker }}</p>
    {%- endif -%}
    <h2>{{ section.settings.heading }}</h2>
    {%- if section.settings.text != blank -%}
      <p>{{ section.settings.text }}</p>
    {%- endif -%}
  </div>

  <div class="scroll-story__cards">
    {%- for block in section.blocks -%}
      {%- liquid
        assign story_product = block.settings.product
        assign story_collection = block.settings.collection
        assign story_image = block.settings.image | default: story_product.featured_media.preview_image | default: story_product.featured_image | default: story_collection.featured_image
        assign story_title = block.settings.title | default: story_product.title | default: story_collection.title
        assign story_text = block.settings.text | default: story_product.description | default: story_collection.description | strip_html | truncatewords: 32
        assign story_link = block.settings.link | default: story_product.url | default: story_collection.url
        assign story_link_label = block.settings.link_label | default: story_product.title | default: story_collection.title
      -%}
      <article class="story-card reveal-item" {{ block.shopify_attributes }}>
        <span class="story-card__number">({{ forloop.index | prepend: '0' | slice: -2, 2 }})</span>
        <div class="story-card__body">
          <h3>{{ story_title | default: 'Story title' }}</h3>
          <div class="story-card__media media-frame">
            {%- render 'responsive-image',
              image: story_image,
              class: 'media-frame__image',
              sizes: '(min-width: 990px) 55vw, 100vw'
            -%}
          </div>
          {%- if story_text != blank -%}
            <p>{{ story_text }}</p>
          {%- endif -%}
          {%- if story_link != blank -%}
            <a class="text-link" href="{{ story_link }}">{{ story_link_label | default: 'Explore' }}</a>
          {%- endif -%}
        </div>
      </article>
    {%- else -%}
      {%- for i in (1..3) -%}
        <article class="story-card reveal-item">
          <span class="story-card__number">({{ forloop.index | prepend: '0' | slice: -2, 2 }})</span>
          <div class="story-card__body">
            <h3>Footwear chapter</h3>
            <div class="story-card__media media-frame">
              {{ 'product-1' | placeholder_svg_tag: 'media-frame__image placeholder-svg' }}
            </div>
            <p>Use this block for shoe fit notes, material stories, collection launches, or performance details.</p>
          </div>
        </article>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Scroll story",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Fit notes"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Footwear stories built for browsing"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Numbered editorial modules give footwear merchants a memorable way to explain fit, cushioning, materials, and use cases."
    }
  ],
  "blocks": [
    {
      "type": "chapter",
      "name": "Chapter",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scroll story",
      "blocks": [
        {
          "type": "chapter"
        },
        {
          "type": "chapter"
        },
        {
          "type": "chapter"
        }
      ]
    }
  ]
}
{% endschema %}
