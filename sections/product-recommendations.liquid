<section class="product-recommendations section-band">
  <div class="page-width">
    <div class="section-heading reveal-item">
      <p class="eyebrow">{{ section.settings.kicker }}</p>
      <h2>{{ section.settings.heading }}</h2>
    </div>

    <product-recommendations
      class="product-recommendations__list"
      data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.products_to_show }}&intent=related"
    >
      {%- if recommendations.performed and recommendations.products_count > 0 -%}
        <div class="product-grid">
          {%- for recommendation in recommendations.products -%}
            {%- render 'product-card', product: recommendation, loading: 'lazy' -%}
          {%- endfor -%}
        </div>
      {%- elsif section.settings.fallback_products != blank -%}
        <div class="product-grid">
          {%- for fallback_product in section.settings.fallback_products limit: section.settings.products_to_show -%}
            {%- render 'product-card', product: fallback_product, loading: 'lazy' -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </product-recommendations>
  </div>
</section>

{% schema %}
{
  "name": "Related products",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Next"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You may also like"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    },
    {
      "type": "product_list",
      "id": "fallback_products",
      "label": "Fallback products",
      "info": "Shown when automatic recommendations are unavailable."
    }
  ],
  "presets": [
    {
      "name": "Related products"
    }
  ]
}
{% endschema %}
