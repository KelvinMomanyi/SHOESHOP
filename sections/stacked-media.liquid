<section class="stacked-media section-band">
  <div class="stacked-media__inner page-width">
    <div class="section-heading reveal-item">
      <p class="eyebrow">{{ section.settings.kicker }}</p>
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.text != blank -%}
        <p>{{ section.settings.text }}</p>
      {%- endif -%}
    </div>

    <div class="stacked-media__deck" data-tilt-stack>
      {%- for block in section.blocks -%}
        {%- liquid
          assign deck_product = block.settings.product
          assign deck_collection = block.settings.collection
          assign image = block.settings.image | default: deck_product.featured_media.preview_image | default: deck_product.featured_image | default: deck_collection.featured_image
          assign title = block.settings.title | default: deck_product.title | default: deck_collection.title
          assign link = block.settings.link | default: deck_product.url | default: deck_collection.url
        -%}
        <a class="deck-card" href="{{ link | default: routes.all_products_collection_url }}" style="--stack-index: {{ forloop.index0 }};" {{ block.shopify_attributes }}>
          {%- render 'responsive-image',
            image: image,
            class: 'deck-card__image',
            sizes: '(min-width: 990px) 28vw, 80vw'
          -%}
          <span>{{ title | default: 'Layered shoe' }}</span>
        </a>
      {%- else -%}
        {%- for i in (1..3) -%}
          <a class="deck-card" href="{{ routes.all_products_collection_url }}" style="--stack-index: {{ forloop.index0 }};">
            {{ 'product-1' | placeholder_svg_tag: 'deck-card__image placeholder-svg' }}
            <span>Layered shoe</span>
          </a>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Stacked media",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "In rotation"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Build a footwear rotation"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "A compact perspective deck for daily trainers, trail shoes, recovery slides, and seasonal footwear."
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Stacked media",
      "blocks": [
        {
          "type": "card"
        },
        {
          "type": "card"
        },
        {
          "type": "card"
        }
      ]
    }
  ]
}
{% endschema %}
