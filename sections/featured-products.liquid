{%- liquid
  assign collection = section.settings.collection
  assign product_limit = section.settings.products_to_show
  assign has_manual_products = false
  for block in section.blocks
    if block.settings.product != blank
      assign has_manual_products = true
      break
    endif
  endfor
  assign stack_count = 4
  if has_manual_products
    assign stack_count = 0
    for block in section.blocks
      if block.settings.product != blank
        assign stack_count = stack_count | plus: 1
      endif
    endfor
  elsif collection.products != blank
    assign stack_count = collection.products.size
    if stack_count > product_limit
      assign stack_count = product_limit
    endif
  endif
  assign scroll_length = stack_count | times: 85 | plus: 140
-%}

<section
  class="featured-products featured-products--stack section-{{ section.id }}"
  data-featured-product-stack
  style="--featured-stack-height: {{ scroll_length }}svh; --featured-stack-count: {{ stack_count }};"
>
  <div class="featured-products__stack-stage">
    <div class="featured-products__stack-intro page-width">
      <div class="section-heading">
        {%- if section.settings.kicker != blank -%}
          <p class="eyebrow">{{ section.settings.kicker }}</p>
        {%- endif -%}
        <h2>{{ section.settings.heading }}</h2>
        {%- if section.settings.text != blank -%}
          <p>{{ section.settings.text }}</p>
        {%- endif -%}
      </div>
    </div>

    <div class="featured-products__stack-deck" data-featured-product-deck>
      {%- if has_manual_products -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.product != blank -%}
            <div
              class="featured-products__stack-card"
              data-featured-product-card
              data-rotate-from="{% cycle '11', '-9', '8', '-12', '10', '-7', '9', '-10', '6', '-8', '12', '-6' %}"
              data-rotate-to="{% cycle '-3', '4', '-5', '3', '-4', '5', '-2', '4', '-5', '3', '-4', '2' %}"
              style="--stack-index: {{ forloop.index0 }};"
              {{ block.shopify_attributes }}
            >
              {%- render 'product-card', product: block.settings.product, collection: collection, loading: 'lazy' -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- elsif collection.products != blank -%}
        {%- for product in collection.products limit: product_limit -%}
          <div
            class="featured-products__stack-card"
            data-featured-product-card
            data-rotate-from="{% cycle '11', '-9', '8', '-12', '10', '-7', '9', '-10', '6', '-8', '12', '-6' %}"
            data-rotate-to="{% cycle '-3', '4', '-5', '3', '-4', '5', '-2', '4', '-5', '3', '-4', '2' %}"
            style="--stack-index: {{ forloop.index0 }};"
          >
            {%- render 'product-card', product: product, collection: collection, loading: 'lazy' -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div
            class="featured-products__stack-card"
            data-featured-product-card
            data-rotate-from="{% cycle '11', '-9', '8', '-12' %}"
            data-rotate-to="{% cycle '-3', '4', '-5', '3' %}"
            style="--stack-index: {{ forloop.index0 }};"
          >
            {%- render 'product-card', product: blank -%}
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <div class="featured-products__stack-progress" aria-hidden="true">
      {%- if section.settings.kicker != blank -%}
        <span>{{ section.settings.kicker }}</span>
      {%- else -%}
        <span>{{ section.settings.heading }}</span>
      {%- endif -%}
      <i data-featured-product-progress></i>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Shoe rotation"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shoes worth a closer look"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "A scroll-stacked sequence for running shoes, daily sneakers, trail styles, and recovery essentials."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Collection products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "limit": 12,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured products"
    }
  ]
}
{% endschema %}
