{%- liquid
  assign collection = section.settings.collection
  assign product_limit = section.settings.products_to_show
-%}

<section class="featured-products section-band">
  <div class="page-width">
    <div class="section-heading reveal-item">
      {%- if section.settings.kicker != blank -%}
        <p class="eyebrow">{{ section.settings.kicker }}</p>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.text != blank -%}
        <p>{{ section.settings.text }}</p>
      {%- endif -%}
    </div>

    <div class="product-grid product-grid--stagger">
      {%- if collection.products != blank -%}
        {%- for product in collection.products limit: product_limit -%}
          {%- render 'product-card', product: product, collection: collection, loading: 'lazy' -%}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          {%- render 'product-card', product: blank -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Product rhythm"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built for browsing"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "A staggered product grid inspired by the rotating image reveals in the Scroll studies."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Featured products"
    }
  ]
}
{% endschema %}
