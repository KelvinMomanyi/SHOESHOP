{%- liquid
  assign featured_product = section.settings.product
  assign current_variant = featured_product.selected_or_first_available_variant
  assign product_form_id = 'product-form-' | append: section.id
-%}

<section class="featured-product product product--featured page-width" data-section-id="{{ section.id }}">
  <div class="product__media-gallery">
    {%- if featured_product.media.size > 0 -%}
      {%- for media in featured_product.media -%}
        {%- liquid
          assign media_loading = 'lazy'
          assign media_alt = media.alt | escape
          if forloop.first
            assign media_loading = 'eager'
          endif
        -%}
        <div class="product-media media-frame" data-media-id="{{ section.id }}-{{ media.id }}">
          {%- case media.media_type -%}
            {%- when 'image' -%}
              {{
                media.preview_image
                | image_url: width: 1600
                | image_tag:
                  widths: '360, 533, 720, 940, 1200, 1500, 1600',
                  sizes: '(min-width: 990px) 50vw, 100vw',
                  loading: media_loading,
                  class: 'media-frame__image',
                  alt: media_alt,
                  style: media.preview_image.presentation.focal_point
              }}
            {%- when 'external_video' -%}
              {{ media | external_video_tag: class: 'product-media__video' }}
            {%- when 'video' -%}
              {{ media | video_tag: controls: true, image_size: '1200x', class: 'product-media__video' }}
            {%- when 'model' -%}
              {{ media | model_viewer_tag: class: 'product-media__model', reveal: 'interaction' }}
            {%- else -%}
              {{ media | media_tag }}
          {%- endcase -%}
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="product-media media-frame">
        {{ 'product-1' | placeholder_svg_tag: 'media-frame__image placeholder-svg' }}
      </div>
    {%- endif -%}
  </div>

  <div class="product__info">
    {%- if featured_product != blank -%}
      {%- form 'product', featured_product, id: product_form_id, class: 'product-form', novalidate: 'novalidate' -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}" data-product-id-input>

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'vendor' -%}
              {%- if featured_product.vendor != blank -%}
                <p class="eyebrow" {{ block.shopify_attributes }}>{{ featured_product.vendor }}</p>
              {%- endif -%}

            {%- when 'title' -%}
              <div class="product__title" {{ block.shopify_attributes }}>
                <h2>{{ featured_product.title }}</h2>
              </div>

            {%- when 'price' -%}
              <div class="product__price" {{ block.shopify_attributes }}>
                {%- render 'price', product: featured_product, use_variant: true -%}
              </div>

            {%- when 'variant_picker' -%}
              {%- unless featured_product.has_only_default_variant -%}
                <variant-selects class="variant-picker" data-section="{{ section.id }}" data-url="{{ featured_product.url }}" {{ block.shopify_attributes }}>
                  {%- for option in featured_product.options_with_values -%}
                    <fieldset class="product-form__input">
                      <legend>{{ option.name }}</legend>
                      <div class="option-values">
                        {%- for value in option.values -%}
                          {%- liquid
                            assign swatch = value.swatch
                            assign option_id = 'FeaturedOption-' | append: section.id | append: '-' | append: option.position | append: '-' | append: forloop.index0
                          -%}
                          <input
                            type="radio"
                            id="{{ option_id }}"
                            name="options[{{ option.name | escape }}]"
                            value="{{ value | escape }}"
                            {% if option.selected_value == value %}checked{% endif %}
                          >
                          <label
                            for="{{ option_id }}"
                            class="option-value{% if swatch.color or swatch.image %} option-value--swatch{% endif %}"
                            {% if swatch.color %}style="--swatch-color: {{ swatch.color }};"{% endif %}
                          >
                            {%- if swatch.image -%}
                              <span class="option-value__swatch" style="background-image: url({{ swatch.image | image_url: width: 96 }});"></span>
                            {%- elsif swatch.color -%}
                              <span class="option-value__swatch"></span>
                            {%- endif -%}
                            <span>{{ value }}</span>
                          </label>
                        {%- endfor -%}
                      </div>
                    </fieldset>
                  {%- endfor -%}
                </variant-selects>
              {%- endunless -%}

            {%- when 'quantity_selector' -%}
              <div class="quantity-field" {{ block.shopify_attributes }}>
                <label for="FeaturedQuantity-{{ section.id }}">{{ 'products.product.quantity' | t }}</label>
                <input class="field__input quantity-input" id="FeaturedQuantity-{{ section.id }}" type="number" name="quantity" value="1" min="1">
              </div>

            {%- when 'selling_plan_picker' -%}
              {%- if featured_product.selling_plan_groups.size > 0 -%}
                <div class="selling-plan-picker" {{ block.shopify_attributes }}>
                  <label for="FeaturedSellingPlan-{{ section.id }}">{{ 'products.product.selling_plan' | t }}</label>
                  <select id="FeaturedSellingPlan-{{ section.id }}" class="field__input" name="selling_plan">
                    <option value="">{{ 'products.product.one_time_purchase' | t }}</option>
                    {%- for group in featured_product.selling_plan_groups -%}
                      <optgroup label="{{ group.name | escape }}">
                        {%- for selling_plan in group.selling_plans -%}
                          <option value="{{ selling_plan.id }}">{{ selling_plan.name }}</option>
                        {%- endfor -%}
                      </optgroup>
                    {%- endfor -%}
                  </select>
                </div>
              {%- endif -%}

            {%- when 'buy_buttons' -%}
              <div class="product-form__buttons" {{ block.shopify_attributes }}>
                <button
                  type="submit"
                  name="add"
                  class="button product-form__submit"
                  {% unless current_variant.available %}disabled{% endunless %}
                  data-add-to-cart
                >
                  <span data-add-to-cart-text>
                    {%- if current_variant.available -%}
                      {{ 'products.product.add_to_cart' | t }}
                    {%- else -%}
                      {{ 'products.product.sold_out' | t }}
                    {%- endif -%}
                  </span>
                </button>

                {%- if block.settings.show_dynamic_checkout -%}
                  {{ form | payment_button }}
                {%- endif -%}

                {{ form | payment_terms }}
              </div>

            {%- when 'description' -%}
              {%- if featured_product.description != blank -%}
                <div class="product__description rte" {{ block.shopify_attributes }}>
                  {{ featured_product.description }}
                </div>
              {%- endif -%}

            {%- when 'pickup_availability' -%}
              <pickup-availability
                class="pickup-availability"
                data-root-url="{{ routes.root_url }}"
                data-variant-id="{{ current_variant.id }}"
                data-section-id="pickup-availability"
                {{ block.shopify_attributes }}
              >
                {%- render 'pickup-availability', product: featured_product -%}
              </pickup-availability>

            {%- when 'custom_liquid' -%}
              <div class="custom-liquid" {{ block.shopify_attributes }}>
                {{ block.settings.custom_liquid }}
              </div>

            {%- when '@app' -%}
              {% render block %}
          {%- endcase -%}
        {%- endfor -%}
      {%- endform -%}

      <script type="application/json" id="ProductJson-{{ section.id }}">
        {{ featured_product.variants | json }}
      </script>
    {%- else -%}
      <div class="product-form">
        <p class="eyebrow">{{ 'products.product.vendor' | t }}</p>
        <div class="product__title"><h2>{{ section.settings.placeholder_heading }}</h2></div>
        <div class="price"><span class="price__regular">{{ 1999 | money }}</span></div>
        <a class="button" href="{{ routes.all_products_collection_url }}">{{ 'cart.general.continue_shopping' | t }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured product",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "placeholder_heading",
      "label": "Placeholder heading",
      "default": "Featured product"
    }
  ],
  "blocks": [
    {
      "type": "vendor",
      "name": "Vendor",
      "limit": 1
    },
    {
      "type": "title",
      "name": "Title",
      "limit": 1
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1
    },
    {
      "type": "variant_picker",
      "name": "Variant picker",
      "limit": 1
    },
    {
      "type": "quantity_selector",
      "name": "Quantity selector",
      "limit": 1
    },
    {
      "type": "selling_plan_picker",
      "name": "Selling plan picker",
      "limit": 1
    },
    {
      "type": "buy_buttons",
      "name": "Buy buttons",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_dynamic_checkout",
          "label": "Show dynamic checkout buttons",
          "default": true
        }
      ]
    },
    {
      "type": "description",
      "name": "Description",
      "limit": 1
    },
    {
      "type": "pickup_availability",
      "name": "Pickup availability",
      "limit": 1
    },
    {
      "type": "custom_liquid",
      "name": "Custom liquid",
      "settings": [
        {
          "type": "liquid",
          "id": "custom_liquid",
          "label": "Custom liquid"
        }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Featured product",
      "blocks": [
        {
          "type": "vendor"
        },
        {
          "type": "title"
        },
        {
          "type": "price"
        },
        {
          "type": "variant_picker"
        },
        {
          "type": "quantity_selector"
        },
        {
          "type": "selling_plan_picker"
        },
        {
          "type": "buy_buttons"
        },
        {
          "type": "description"
        },
        {
          "type": "pickup_availability"
        }
      ]
    }
  ]
}
{% endschema %}
