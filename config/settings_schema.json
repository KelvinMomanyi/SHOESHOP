[
  {
    "name": "theme_info",
    "theme_name": "Scrollcraft",
    "theme_version": "1.0.0",
    "theme_author": "Original theme",
    "theme_documentation_url": "https://shopify.dev/docs/storefronts/themes",
    "theme_support_url": "https://help.shopify.com/"
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      },
      {
        "type": "image_picker",
        "id": "social_sharing_image",
        "label": "Social sharing image"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_body_font",
        "label": "Body font",
        "default": "inter_n4"
      },
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "label": "Heading font",
        "default": "syne_n7"
      },
      {
        "type": "font_picker",
        "id": "type_mono_font",
        "label": "Utility font",
        "default": "ibm_plex_mono_n4"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_background",
        "label": "Background",
        "default": "#f6f4ef"
      },
      {
        "type": "color",
        "id": "color_foreground",
        "label": "Text",
        "default": "#111111"
      },
      {
        "type": "color",
        "id": "color_muted",
        "label": "Muted text",
        "default": "#67645d"
      },
      {
        "type": "color",
        "id": "color_surface",
        "label": "Surface",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Borders",
        "default": "#d8d4cb"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent",
        "default": "#a6bd2f"
      },
      {
        "type": "color",
        "id": "color_accent_2",
        "label": "Secondary accent",
        "default": "#e56b48"
      },
      {
        "type": "color",
        "id": "color_button",
        "label": "Button",
        "default": "#111111"
      },
      {
        "type": "color",
        "id": "color_button_text",
        "label": "Button text",
        "default": "#ffffff"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 960,
        "max": 1600,
        "step": 20,
        "unit": "px",
        "label": "Page width",
        "default": 1360
      },
      {
        "type": "checkbox",
        "id": "enable_scroll_reveal",
        "label": "Enable scroll reveal animation",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_payment_icons",
        "label": "Show payment icons",
        "default": true
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "url",
        "id": "social_instagram_link",
        "label": "Instagram"
      },
      {
        "type": "url",
        "id": "social_tiktok_link",
        "label": "TikTok"
      },
      {
        "type": "url",
        "id": "social_youtube_link",
        "label": "YouTube"
      },
      {
        "type": "url",
        "id": "social_pinterest_link",
        "label": "Pinterest"
      }
    ]
  }
]
