{%- liquid
  assign seo_title = page_title | default: shop.name
  assign seo_description = page_description | default: shop.description | default: shop.name
  assign social_image = page_image | default: settings.social_sharing_image
-%}

<title>
  {{ seo_title }}
  {%- unless seo_title contains shop.name -%}
    &ndash; {{ shop.name }}
  {%- endunless -%}
</title>

{%- if seo_description -%}
  <meta name="description" content="{{ seo_description | escape }}">
{%- endif -%}

<meta property="og:site_name" content="{{ shop.name | escape }}">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:title" content="{{ seo_title | escape }}">
<meta property="og:type" content="{% if request.page_type == 'product' %}product{% else %}website{% endif %}">
<meta property="og:description" content="{{ seo_description | escape }}">

{%- if social_image -%}
  <meta property="og:image" content="{{ social_image | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="{{ social_image | image_url: width: 1200 }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="{{ 1200 | divided_by: social_image.aspect_ratio | round }}">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta property="og:price:amount" content="{{ product.selected_or_first_available_variant.price | money_without_currency | strip_html }}">
  <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ seo_title | escape }}">
<meta name="twitter:description" content="{{ seo_description | escape }}">
{%- if social_image -%}
  <meta name="twitter:image" content="{{ social_image | image_url: width: 1200 }}">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": {{ product.title | json }},
      "description": {{ product.description | strip_html | json }},
      "sku": {{ product.selected_or_first_available_variant.sku | json }},
      "brand": {
        "@type": "Brand",
        "name": {{ product.vendor | json }}
      },
      "image": [
        {%- for image in product.images -%}
          {{ image | image_url: width: 1200 | prepend: 'https:' | json }}{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ],
      "offers": [
        {%- for variant in product.variants -%}
          {
            "@type": "Offer",
            "sku": {{ variant.sku | json }},
            "url": {{ shop.url | append: variant.url | json }},
            "priceCurrency": {{ cart.currency.iso_code | json }},
            "price": {{ variant.price | money_without_currency | replace: ',', '' | json }},
            "availability": "https://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
            "itemCondition": "https://schema.org/NewCondition"
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    }
  </script>
{%- endif -%}
