{%- liquid
  assign image_class = class | default: ''
  assign image_sizes = sizes | default: '100vw'
  assign image_widths = widths | default: '165, 360, 533, 720, 940, 1200, 1600, 2000'
  assign image_loading = loading | default: 'lazy'
  assign image_alt = alt | default: image.alt | escape
-%}

{%- if image != blank -%}
  {{
    image
    | image_url: width: 2000
    | image_tag:
      widths: image_widths,
      sizes: image_sizes,
      loading: image_loading,
      class: image_class,
      alt: image_alt
  }}
{%- else -%}
  {{ 'product-1' | placeholder_svg_tag: image_class }}
{%- endif -%}
