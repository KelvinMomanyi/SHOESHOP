<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}" dir="{{ request.locale.direction }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_background }}">
    <title>{{ shop.name }}</title>
    {{ content_for_header }}
    {%- liquid
      assign body_font = settings.type_body_font
      assign body_font_bold = body_font | font_modify: 'weight', 'bold'
      assign body_font_italic = body_font | font_modify: 'style', 'italic'
      assign body_font_bold_italic = body_font_bold | font_modify: 'style', 'italic'
      assign heading_font = settings.type_heading_font
      assign heading_font_bold = heading_font | font_modify: 'weight', 'bold'
      assign heading_font_italic = heading_font | font_modify: 'style', 'italic'
      assign heading_font_bold_italic = heading_font_bold | font_modify: 'style', 'italic'
      assign mono_font = settings.type_mono_font
      assign mono_font_bold = mono_font | font_modify: 'weight', 'bold'
      assign mono_font_italic = mono_font | font_modify: 'style', 'italic'
      assign mono_font_bold_italic = mono_font_bold | font_modify: 'style', 'italic'
    -%}
    <style>
      {{ body_font | font_face: font_display: 'swap' }}
      {{ body_font_bold | font_face: font_display: 'swap' }}
      {{ body_font_italic | font_face: font_display: 'swap' }}
      {{ body_font_bold_italic | font_face: font_display: 'swap' }}
      {{ heading_font | font_face: font_display: 'swap' }}
      {{ heading_font_bold | font_face: font_display: 'swap' }}
      {{ heading_font_italic | font_face: font_display: 'swap' }}
      {{ heading_font_bold_italic | font_face: font_display: 'swap' }}
      {{ mono_font | font_face: font_display: 'swap' }}
      {{ mono_font_bold | font_face: font_display: 'swap' }}
      {{ mono_font_italic | font_face: font_display: 'swap' }}
      {{ mono_font_bold_italic | font_face: font_display: 'swap' }}

      :root {
        --font-body: {{ body_font.family }}, {{ body_font.fallback_families }};
        --font-heading: {{ heading_font.family }}, {{ heading_font.fallback_families }};
        --font-mono: {{ mono_font.family }}, {{ mono_font.fallback_families }};
        --color-background: {{ settings.color_background }};
        --color-foreground: {{ settings.color_foreground }};
        --color-surface: {{ settings.color_surface }};
        --color-surface-text: {{ settings.color_surface_text }};
        --color-accent: {{ settings.color_accent }};
        --color-accent-text: {{ settings.color_accent_text }};
        --color-button: {{ settings.color_button }};
        --color-button-text: {{ settings.color_button_text }};
      }
    </style>
    {{ 'theme.css' | asset_url | stylesheet_tag }}
  </head>
  <body class="template-password">
    <main id="MainContent" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>
  </body>
</html>
